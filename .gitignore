# ===========================
# NearFind — .gitignore
# ===========================
# Only core source files are tracked.
# Everything else (dependencies, builds, caches) can be
# regenerated with: npm install && cd android && ./gradlew assembleRelease

# ----------------------------
# Dependencies
# ----------------------------
node_modules/
.bundle/

# ----------------------------
# Build outputs
# ----------------------------
build/
*.apk
*.aab
*.jsbundle
*.jsbundle.map

# ----------------------------
# Android / Gradle
# ----------------------------
.gradle/
.cxx/
.kotlin/
local.properties
*.iml
*.hprof
android/build/
android/app/build/
android/.gradle/
android/app/.cxx/
android/app/release/

# Keystores (sensitive — never push)
*.keystore
*.jks
!android/app/debug.keystore

# ----------------------------
# iOS / Xcode (not used but good practice)
# ----------------------------
ios/Pods/
ios/build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local

# ----------------------------
# IDE & Editor configs
# ----------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----------------------------
# OS files
# ----------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------
# Metro bundler
# ----------------------------
.metro-health-check*

# ----------------------------
# Logs & debug
# ----------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ----------------------------
# Testing & Coverage
# ----------------------------
/coverage/

# ----------------------------
# Fastlane
# ----------------------------
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# ----------------------------
# Ruby / CocoaPods
# ----------------------------
**/Pods/
/vendor/bundle/
.ruby-version

# ----------------------------
# Yarn
# ----------------------------
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ----------------------------
# Temporary & utility scripts
# ----------------------------
fix_icons.js

# ----------------------------
# Misc
# ----------------------------
*.orig
*.bak
*.tmp
